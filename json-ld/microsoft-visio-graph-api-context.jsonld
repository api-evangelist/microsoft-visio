    "height": { "@id": "ms:height", "@type": "xsd:double" },
    "width": { "@id": "ms:width", "@type": "xsd:double" },
    "text": { "@id": "ms:text", "@type": "xsd:string" },
    "type": { "@id": "ms:type", "@type": "xsd:string" },
    "label": { "@id": "ms:label", "@type": "xsd:string" },
    "value": { "@id": "ms:value", "@type": "xsd:string" },
    "format": { "@id": "ms:format", "@type": "xsd:string" },
    "author": { "@id": "ms:author", "@type": "xsd:string" },
    "date": { "@id": "ms:date", "@type": "xsd:dateTime" },
    "address": { "@id": "ms:address", "@type": "@id" },
    "subAddress": { "@id": "ms:subAddress", "@type": "xsd:string" }
  }
}
